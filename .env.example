# =============================================================================
# ENV REFERENCE — copy relevant sections to the correct file
# =============================================================================
#
# This file is committed to git. NEVER put real secrets here.
# Real values live in THREE places:
#
#  1. .env.local          — Next.js app (API routes, server components)
#  2. Supabase secrets    — Edge functions only (set via: npx supabase secrets set KEY=value)
#  3. video-worker/.env   — Python video worker
#
# Variables marked [Supabase] are set ONLY via `npx supabase secrets set`.
# They are NOT read by the Next.js app and do not belong in .env.local.
# Variables marked [Both] need to be set in .env.local AND Supabase secrets.
#
# =============================================================================


# =============================================================================
# SECTION 1 — Browser-safe public config (.env.local)
# =============================================================================
# Safe to expose in the browser. Must start with NEXT_PUBLIC_.

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_APP_URL="https://yourapp.com"

# Feature flags
NEXT_PUBLIC_ENABLE_PROMPT_SUGGESTIONS_EDGE_IN_DEV="false"

# Payment publishable/public keys (safe in browser)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""


# =============================================================================
# SECTION 2 — Next.js server secrets (.env.local)
# =============================================================================
# Server-only. Read by API routes and server components. Never sent to browser.

# Supabase (auto-available in edge functions — only needed here for API routes)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# AI providers [Both — also set in Supabase secrets for edge functions]
GROQ_API_KEY="gsk_..."       # get from console.groq.com/keys
GROQ_MODEL=""                # optional edge/app override
ANTHROPIC_API_KEY=""         # get from console.anthropic.com
ANTHROPIC_MODEL=""           # optional edge/app override
DEFAULT_AI_MODEL=""          # optional: anthropic/groq preference for edge LLM helper
FAL_API_KEY=""               # get from fal.ai/dashboard — REQUIRED for image + video generation

# Real OAuth / publishing credentials [Both for OAuth callback + edge publishing]
OAUTH_STATE_SECRET="generate-a-random-string-here"
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
X_CLIENT_ID=""
X_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Media generation [Both — also set in Supabase secrets]
FREEPIK_API_KEY=""

# Email [Both — also set in Supabase secrets]
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Cron job auth — protects /api/cron/* routes
CRON_SECRET="generate-a-random-string-here"

# Video worker integration
VIDEO_WORKER_WEBHOOK_SECRET=""
WORKER_WEBHOOK_URL="http://localhost:8001"

# Video engine mock flags (set to "false" in production)
VIDEO_ENGINE_USE_MOCK_ANTHROPIC="true"
VIDEO_ENGINE_USE_MOCK_REPLICATE="true"
VIDEO_ENGINE_USE_MOCK_PAYMENTS="true"

# Payment server secrets
PAYSTACK_SECRET_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_GBP_HOURLY_RATE="35"
STRIPE_USD_HOURLY_RATE="45"

# Admin
PRICE_MANAGEMENT_PASSWORD=""
ASSESSMENT_REVIEW_REQUIRED="false"


# =============================================================================
# SECTION 3 — Supabase edge function secrets only
# =============================================================================
# Set with: npx supabase secrets set KEY=value
# These are NOT read by Next.js. Do not add them to .env.local.
#
# Check current secrets: npx supabase secrets list
#
# Already set in Supabase (auto-managed — do not touch):
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#   SUPABASE_DB_URL, SUPABASE_JWKS, SUPABASE_PUBLISHABLE_KEYS,
#   SUPABASE_SECRET_KEYS
#
# Set these manually if not already configured:

# AI providers (edge functions)
# GROQ_API_KEY="gsk_..."         ← same key as Section 2
# GROQ_MODEL=""                  ← optional model override
# ANTHROPIC_API_KEY=""           ← same key as Section 2
# ANTHROPIC_MODEL=""             ← optional: override default claude model (e.g. claude-3-5-haiku-latest)
# DEFAULT_AI_MODEL=""            ← optional provider preference: anthropic or groq
# REPLICATE_API_TOKEN=""         ← same key as Section 2

# Platform publishing credentials (edge functions)
# INSTAGRAM_APP_ID=""
# INSTAGRAM_APP_SECRET=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
# X_CLIENT_ID=""
# X_CLIENT_SECRET=""
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""

# Additional AI/media providers (edge functions only — not used in Next.js)
# GEMINI_API_KEY=""              ← Google Gemini
# MAGNIFIC_API_KEY=""            ← Image upscaling
# POLLINATION_API_KEY=""         ← Image generation

# Email (edge functions)
# RESEND_API_KEY=""              ← same key as Section 2
# RESEND_FROM_EMAIL=""
# FROM_EMAIL="noreply@yourapp.com"
# FROM_NAME="Your App Name"

# App URL for edge function redirects
# APP_URL="https://yourapp.com"
# SITE_URL="https://yourapp.com"
# PUBLIC_APP_URL="https://yourapp.com"


# =============================================================================
# SECTION 4 — Python video worker (video-worker/.env)
# =============================================================================
# Copy this block into video-worker/.env. Not read by Next.js.

# WORKER_SUPABASE_URL="https://your-project.supabase.co/rest/v1/"
# WORKER_SUPABASE_SERVICE_KEY="your-service-role-key"
# WORKER_WEBHOOK_SECRET=""           # Must match VIDEO_WORKER_WEBHOOK_SECRET above
# WORKER_ANTHROPIC_API_KEY=""        # Can share with main ANTHROPIC_API_KEY
# WORKER_REPLICATE_API_TOKEN=""      # Can share with main REPLICATE_API_TOKEN

# Worker runtime flags
# WORKER_USE_MOCK_ANTHROPIC="true"   # Set to "false" in production
# WORKER_USE_MOCK_REPLICATE="true"   # Set to "false" in production

# Worker tuning (defaults are fine for most setups)
# WORKER_TEMP_DIR="/tmp/video-engine"
# WORKER_MAX_CONCURRENT_JOBS="3"
# WORKER_POLL_INTERVAL_SECONDS="5"
# WORKER_STUCK_JOB_THRESHOLD_MINUTES="30"
# WORKER_PORT="8001"
# WORKER_LOG_LEVEL="INFO"


# =============================================================================
# SECTION 5 — Local tooling (.env)
# =============================================================================
# Only used by Prisma and local DB tools. Not read by Next.js or edge functions.

# DATABASE_URL=""


# =============================================================================
# SECTION 6 - Browser E2E validation (.env.local or CI env)
# =============================================================================
# Used only by Playwright tests. Do not commit real credentials.
#
# E2E_BASE_URL="http://localhost:3001"
# E2E_USER_EMAIL=""
# E2E_USER_PASSWORD=""
# E2E_ADMIN_EMAIL=""
# E2E_ADMIN_PASSWORD=""
# E2E_ORG_EMAIL=""
# E2E_ORG_PASSWORD=""
# E2E_ORG_ID=""
#
# Set E2E_REQUIRE_AUTH="1" in CI when authenticated journeys must run.
