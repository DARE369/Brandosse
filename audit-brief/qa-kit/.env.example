# Copy this file to `.env` in this same folder and fill in real values.
# Never commit the real `.env` — it holds your service-role key and two
# real account passwords. `.env` is already covered by the repo's root
# .gitignore pattern for `.env*`; double-check before committing anything.

# ── Supabase project ─────────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Settings → API → Project API keys → service_role (SECRET — server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Test account #1 (primary) ────────────────────────────────────────────
# A real, free account in this project with at least 20 credits and one
# MOCK connected account (is_mock=true) set up for the platform you'll test
# scheduled-publish with. See RUNBOOK.md Part A for how to create both.
TEST_USER_EMAIL=qa-verify-1@example.com
TEST_USER_PASSWORD=change-me

# ── Test account #2 (secondary, for cross-user checks) ───────────────────
# A second, separate account — only needs to exist and be able to log in.
# Used ONLY to prove user #2 cannot read/subscribe to user #1's data.
TEST_USER_2_EMAIL=qa-verify-2@example.com
TEST_USER_2_PASSWORD=change-me

# ── Optional: only used by verify-video-jobs.js ──────────────────────────
# A small, real, publicly-reachable image URL (any static PNG/JPG you
# control or a stock image host) used as the source image for STANDARD-tier
# (Hailuo, ~5 credits) video test submissions. If left blank, the video
# script falls back to a text-to-video request, which the app's own
# tier-upgrade logic bills at PREMIUM (~15 credits) instead — the script
# will print a clear warning about this before spending anything.
TEST_IMAGE_URL = 
